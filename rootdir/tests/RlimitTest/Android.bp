android_test {
    name: "CtsRlimitTestCases",
    defaults: ["cts_defaults"],
    compile_multilib: "both",
    srcs: ["src/**/*.java"],
    jni_libs: ["libctsrlimit_jni"],
    static_libs: [
        "androidx.test.rules",
        "androidx.test.runner",
        "ctstestrunner-axt",
        "compatibility-device-util-axt",
    ],
    sdk_version: "current",
    test_suites: [
        "cts",
        "general-tests",
    ],
}

cc_library_shared {
    name: "libctsrlimit_jni",
    srcs: ["jni/**/*.cpp"],
    header_libs: ["jni_headers"],
    shared_libs: ["liblog"],
    sdk_version: "current",
}

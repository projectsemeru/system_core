package {
    // See: http://go/android-license-faq
    // A large-scale-change added 'default_applicable_licenses' to import
    // all of the 'license_kinds' from "system_core_init_license"
    // to get the below license kinds:
    //   SPDX-license-identifier-Apache-2.0
    default_applicable_licenses: ["system_core_init_license"],
}

// Many years ago, there was a bug when too many processes were killed, init
// would hang. This test ensures that doesn't happen. However, if every process
// in Android can withstand being killed, then it will make a good phone.
cc_test {
    name: "init_kill_services_test",
    srcs: ["init_kill_services_test.cpp"],
    shared_libs: [
        "libbase",
        "libhidlbase",
    ],
    test_suites: ["general-tests"],

    // TODO(b/153565474): switch back to auto-generation
    // and add back:
    //     require_root: true,
    auto_gen_config: false,
}

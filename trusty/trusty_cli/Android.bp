package {
    default_applicable_licenses: ["Android-Apache-2.0"],
}

cc_binary {
    name: "trusty_cli",
    vendor: true,

    srcs: ["main.cpp"],
    shared_libs: [
        "libc",
        "liblog",
    ],
    static_libs: [
        "libtrusty",
        "libtrustycliinterface",
    ],
    cflags: [
        "-Wall",
        "-Werror",
    ],
}
